root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{cpp,h,hpp}]
indent_style = space
indent_size = 4

[*.vala]
indent_style = space
indent_size = 4

[*.{yaml,yml,md}]
indent_style = space
indent_size = 2
